# 上游 API 配置（必填）
CRAWLER_TASK_URL=http://your-server/renren-api/classify/open/crawler/tasks
CRAWLER_CALLBACK_URL=http://your-server/renren-api/classify/open/crawler/callback
# 照片回传接口：不配则为空，图片上传静默关闭（任务照跑但照片不上传，无报错）
CRAWLER_IMAGE_UPLOAD_URL=http://your-server/renren-api/classify/open/image/upload
CRAWLER_NODE_TOKEN=your-token-here

# 节点配置
CRAWLER_NODE_PREFIX=win-crawler
CRAWLER_NODE_COUNT=1

# 爬虫行为
CRAWLER_POLL_INTERVAL=5000
CRAWLER_POLL_LIMIT=5
CRAWLER_BASE_URL=https://eur.vevor.com
# 多区域映射（可选）：留空时默认区域=EU 且站点=CRAWLER_BASE_URL
# 区域码：EU 欧盟 / GB 英国 / CA 加拿大 / US 美国 / CN 中国（留空=禁用）
# 注意：US 内置禁用——2026-07-12 烟测证实 DE 出口访问 www.vevor.com 被按德国 IP 地理重定向到
#       www.vevor.de，返回错误区域数据。待 US 出口代理/US 节点就绪前，生产勿启用 US（保持 EU/GB/CA）。
# CRAWLER_REGIONS='EU=https://eur.vevor.com,GB=https://www.vevor.co.uk,CA=https://www.vevor.ca'
# CRAWLER_DEFAULT_REGION=EU
# 跨区域 cookie 护栏（默认关）：通道热切换区域时清空 cookie 防串扰
# CRAWLER_CLEAR_COOKIES_ON_REGION_SWITCH=false
CRAWLER_HEADLESS=true

# 可选：代理
# CRAWLER_PROXY=http://proxy.example.com:8080

# 可选：浏览器路径（容器内通常不需要）
# CRAWLER_BROWSER_PATH=

# 必须：禁用 headed 兜底，否则 headless 超时会尝试启动 headed Chromium
# 而容器内没有 X server / Xvfb，会直接报错。Windows / Linux Docker 部署都建议关闭。
CRAWLER_HEADED_FALLBACK=false
