{
  "title": "Crawler · 节点心跳",
  "uid": "crawler-nodes",
  "schemaVersion": 39,
  "version": 2,
  "tags": ["crawler"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "nodeCode",
        "label": "节点",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({app=\"crawler\"}, nodeCode)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "节点列表（最后心跳）",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "max by (nodeCode) (timestamp({app=\"crawler\", job=\"docker\", nodeCode=~\".+\"} | json))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 120, "color": "yellow" },
              { "value": 300, "color": "red" }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "displayName", "value": "最后活跃时间" },
              { "id": "unit", "value": "dateTimeAsIso" }
            ]
          }
        ]
      },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Value #A (count)": true },
            "renameByName": { "Value #A (lastNotNull)": "最后活跃时间" }
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Blackbox 探活（8 容器）",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(probe_success{job=\"blackbox\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 8, "color": "green" }
            ]
          }
        }
      }
    }
  ]
}
