{
  "title": "Crawler · 节点心跳",
  "uid": "crawler-nodes",
  "schemaVersion": 39,
  "version": 3,
  "tags": ["crawler"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "nodeCode",
        "label": "节点",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({app=\"crawler\", nodeCode=~\".+\"}, nodeCode)",
        "refresh": 1,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "节点列表（最近 1h 日志数）",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (nodeCode) (count_over_time({app=\"crawler\", job=\"docker\", nodeCode=~\".+\"} [1h]))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "最近 1h 日志条数" }
            ]
          }
        ]
      },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Blackbox 探活（8 容器）",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(probe_success{job=\"blackbox\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 8, "color": "green" }
            ]
          }
        }
      }
    }
  ]
}
